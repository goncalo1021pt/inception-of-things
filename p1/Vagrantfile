Vagrant.configure("2") do |config|

	config.vm.box = "bento/debian-12"
	config.vm.boot_timeout = 600
	config.vm.communicator = "ssh"

	config.vm.define "goncaloS" do |goncaloS|
		goncaloS.vm.hostname = "GoncaloS"
		goncaloS.vm.network "private_network", ip: "192.168.56.110"
		goncaloS.vm.provider "virtualbox" do |vb|
			vb.memory = "512"
			vb.cpus = 1
			vb.name = "p1_goncaloS"
		end
		goncaloS.vm.provision "shell", inline: <<-SHELL
			apt-get update
			apt-get install -y -q curl
			curl -sfL https://get.k3s.io | K3S_KUBECONFIG_MODE="644" sh -
			echo "K3S Server started, waiting for token..."
			timeout 120 bash -c 'while [ ! -f /var/lib/rancher/k3s/server/node-token ]; do sleep 1; done'
			cp /var/lib/rancher/k3s/server/node-token /vagrant/k3s-token
			echo "Token copied to /vagrant/k3s-token"
		SHELL
	end

	config.vm.define "goncaloSW" do |goncaloSW|
		goncaloSW.vm.hostname = "GoncaloSW"
		goncaloSW.vm.network "private_network", ip: "192.168.56.111"
		goncaloSW.vm.provider "virtualbox" do |vb|
			vb.memory = "512"
			vb.cpus = 1
			vb.name = "p1_goncaloSW"
		end
		goncaloSW.vm.provision "shell", inline: <<-SHELL
			apt-get update
			apt-get install -y -q curl
			echo "Waiting for K3S token from server..."
			timeout 120 bash -c 'while [ ! -f /vagrant/k3s-token ]; do sleep 1; done'
			K3S_TOKEN=$(cat /vagrant/k3s-token)
			K3S_URL="https://192.168.56.110:6443"
			curl -sfL https://get.k3s.io | K3S_URL=$K3S_URL K3S_TOKEN=$K3S_TOKEN sh -
			echo "K3S Agent started"
		SHELL
	end

end